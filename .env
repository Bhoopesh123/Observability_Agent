APP_HOST=0.0.0.0
APP_PORT=8000
FRONTEND_PORT=3005

# Optional LLM settings. If OPENAI_API_KEY is not set, the supervisor uses
# deterministic local summarization so the app still works.
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4.1-mini

# Grafana settings.
GRAFANA_URL=http://localhost:3000
GRAFANA_API_KEY=
GRAFANA_ORG_ID=1
DEFAULT_DATASOURCE_UID=cfnb9z43chlogf
DEFAULT_LOKI_DATASOURCE_UID=

# Query defaults.
DEFAULT_LOOKBACK_MINUTES=30
REQUEST_TIMEOUT_SECONDS=15
